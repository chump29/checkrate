{
  "name": "@postfmly/checkrate",
  "version": "1.0.11",
  "description": "Discord rate limiter",
  "keywords": [
    "discord",
    "rate",
    "limiter"
  ],
  "homepage": "https://github.com/chump29/checkrate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/checkrate.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "bun run build:clean && bun run build:build && bun run build:dts && bun run build:copy && bun run build:rm",
    "build:build": "bun run build.ts",
    "build:clean": "rimraf dist",
    "build:copy": "cp -f LICENSE package.json README.md dist/",
    "build:dts": "bunx tsc --declaration --emitDeclarationOnly --outDir dist --noEmit false --skipLibCheck",
    "build:rm": "rimraf dist/build.d.ts dist/test",
    "clean": "rimraf bun.lock .vscode dist coverage",
    "clean:coverage": "rimraf coverage",
    "lint": "bun run lint:spell && bun run lint:biome && bun run lint:env",
    "lint:biome": "biome check --write --verbose .",
    "lint:env": "dotenv-linter check .",
    "lint:spell": "cspell --dot --verbose .",
    "prepare": "link-configs",
    "test": "bun run clean:coverage && bun test --coverage --isolate --coverage-reporter=text --coverage-reporter=lcov"
  },
  "overrides": {
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "discord.js-rate-limiter": "^1.3.2",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@ngneat/falso": "^8.0.2",
    "@types/ms": "^2.1.0",
    "cspell": "^10.0.1",
    "lcov-total": "^2.1.1",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "@postfmly/config": "^1.3.13",
    "@postfmly/logger": "^1.0.17",
    "discord.js": "^14.26.4"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "~1.3.14"
  },
  "engineStrict": true
}
