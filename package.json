{
  "name": "@postfmly/checkrate",
  "version": "1.0.1",
  "description": "Discord rate limiter",
  "keywords": [
    "discord",
    "rate",
    "limiter"
  ],
  "homepage": "https://github.com/chump29/checkrate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/checkrate.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "bun run build:clean && bun run build:build && bun run build:dts && bun run build:copy && bun run build:rm",
    "build:build": "bun build index.ts --target bun --minify --outdir dist",
    "build:clean": "rimraf dist",
    "build:copy": "cp -f LICENSE package.json README.md dist/",
    "build:dts": "bunx tsc --declaration --emitDeclarationOnly --outDir dist --noEmit false --skipLibCheck",
    "build:rm": "rm dist/index.test.d.ts",
    "clean": "rimraf node_modules bun.lock .vscode dist coverage",
    "clean:coverage": "rimraf coverage",
    "lint": "biome check --write --verbose .",
    "prepare": "config-init",
    "test": "bun run clean:coverage && bun test --coverage --isolate --coverage-reporter=text --coverage-reporter=lcov"
  },
  "dependencies": {
    "@postfmly/logger": "^1.0.1",
    "discord.js-rate-limiter": "^1.3.2",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@nano-faker/number": "^1.0.1",
    "@postfmly/config": "^1.2.15",
    "@types/ms": "^2.1.0",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "discord.js": "^14.26.4"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": "~1.3.13"
  },
  "engineStrict": true
}
